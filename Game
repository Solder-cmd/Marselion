import pygame as pg
from Settings import *
from Sprites import *
import shelve

class Game:
    def __init__(self):
        pg.init()
        pg.mixer.init()

        pg.mixer.music.load(path + 'background.mp3')

        self.SHOOT_SOUND = pg.mixer.Sound(path + 'shootLaser.wav')
        self.EXPLOSION_SOUND = pg.mixer.Sound(path + 'fighterKill.wav')
        self.EXPLOSION_MOB = pg.mixer.Sound(path + 'meteorKill.wav')

        pg.mixer.music.play(-1)

        self.screen = pg.display.set_mode((WIDTH, HEIGHT))
        pg.display.set_caption('THE SPACE SHOOTER')
        pg.display.toggle_fullscreen()

        self.font_name = pg.font.match_font('Tonto', 5)
        self.clock = pg.time.Clock()

        self.running = True
        self.playing = False

        self.background = PGIMLOAD(path + 'Starscape.png')

        self.GAME_START = pg.transform.scale(
            PGIMLOAD(path + 'GAME_START.png'),
            (WIDTH, HEIGHT)
        )

        self.GAME_OVER_HIGH_SCORE = pg.transform.scale(
            PGIMLOAD(path + 'GAME_OVER_HIGH_SCORE.png'),
            (WIDTH, HEIGHT)
        )

        self.GAME_OVER = pg.transform.scale(
            PGIMLOAD(path + 'GO.png'),
            (WIDTH, HEIGHT)
        )

        self.GAME_PAUSE = pg.transform.scale(
            PGIMLOAD(path + 'GAME_PAUSE.png'),
            (WIDTH, HEIGHT)
        )

        self.life = PGIMLOAD(path + 'life.png')

        self.musicPlaying = True

        self.high_score = self.load_high_score()

        self.new()

    def load_high_score(self):
        x = 0

        try:
            s = shelve.open('high_score.db')
            x = s['high_score']
            s.close()

        except:
            pass

        finally:
            return x

    def save_high_score(self):
        try:
            s = shelve.open('high_score.db')
            s['high_score'] = self.high_score
            s.close()

        except:
            pass

    def new(self):
        while self.running:
            self.start_screen()
            self.game_loop()
            self.game_over()

    def new_game(self):
        self.font = pg.font.Font(self.font_name, TEXTSIZE)

        self.all_sprites = pg.sprite.Group()
        self.bullets = pg.sprite.Group()
        self.mobs = pg.sprite.Group()
        self.mobs_bullets = pg.sprite.Group()
        self.meteorites = pg.sprite.Group()

        self.playing = True

        self.player = Player(
            self.all_sprites,
            self.bullets,
            self.SHOOT_SOUND,
            self.EXPLOSION_SOUND
        )

        for i in range(1, 10):
            Mob(
                self.mobs,
                self.meteorites,
                self.all_sprites,
                self.EXPLOSION_MOB
            )

        for i in range(1, 5):
            Enemy(
                self.mobs,
                self.mobs_bullets,
                self.all_sprites,
                self.EXPLOSION_MOB
            )

    def start_screen(self):
        run = True

        while run:
            self.clock.tick(FPS)

            for event in pg.event.get():

                if event.type == pg.QUIT:
                    run = False
                    self.playing = False
                    self.running = False

                if event.type == pg.KEYDOWN:

                    if event.key == pg.K_TAB:
                        run = False
                        self.playing = False
                        self.running = False

                    if event.key == pg.K_n:
                        self.new_game()
                        run = False
                        print('new game started')

                    if event.key == pg.K_ESCAPE:
                        run = False
                        self.game_over()

            self.screen.blit(self.GAME_START, (0, 0))
            pg.display.flip()

    def pause(self):
        run = True

        while run:
            self.clock.tick(FPS)

            for event in pg.event.get():

                if event.type == pg.QUIT:
                    self.playing = False
                    self.running = False
                    run = False

                if event.type == pg.KEYDOWN:

                    if event.key == pg.K_TAB:
                        self.playing = False
                        self.running = False
                        run = False

                    elif event.key == pg.K_x:
                        self.playing = False
                        self.running = False
                        run = False

                    elif event.key == pg.K_ESCAPE:
                        run = False

                    elif event.key == pg.K_n:
                        self.new()
                        run = False

                    elif event.key == pg.K_m:

                        if self.musicPlaying:
                            self.musicPlaying = False
                            print('music stopped')
                            pg.mixer.music.pause()

                        else:
                            print('music resumed')
                            self.musicPlaying = True
                            pg.mixer.music.unpause()

            self.screen.blit(self.GAME_PAUSE, (0, 0))
            pg.display.flip()

    def game_over(self):
        self.now = pg.time.get_ticks()

        pg.mixer.music.pause()

        while pg.time.get_ticks() - self.now < 3000:
            self.clock.tick(FPS)

        run = True
        high = False

        if self.player.score > self.high_score:

            self.high_score = self.player.score

            font = pg.font.Font(self.font_name, 100)

            text = font.render(
                str(self.high_score),
                True,
                (255, 255, 255)
            )

            self.save_high_score()

            high = True

        while run:
            self.clock.tick(FPS)

            for event in pg.event.get():

                if event.type == pg.QUIT:
                    run = False
                    self.running = False

                if event.type == pg.KEYDOWN:

                    if event.key == pg.K_TAB:
                        run = False
                        self.running = False

                    if event.key == pg.K_n:
                        run = False

            if high:
                self.screen.blit(self.GAME_OVER_HIGH_SCORE, (0, 0))
                self.screen.blit(text, (250, 350))

            else:
                self.screen.blit(self.GAME_OVER, (0, 0))

            pg.display.flip()

    def drawScore(self, score):
        text = self.font.render(score, True, TEXTCOLOR)
        self.screen.blit(text, (WIDTH / 2, 10))

    def drawHealth(self, health):
        pg.draw.rect(
            self.screen,
            pg.color.Color('WHITE'),
            (10, 10, WIDTH / 2 - 20, 30),
            2
        )

        pg.draw.rect(
            self.screen,
            pg.color.Color('GREEN'),
            (15, 15, health * (WIDTH / 2 - 30) / 100, 20)
        )

    def drawLife(self, life):
        x = WIDTH - 51

        for i in range(life):
            self.screen.blit(self.life, (x, 10))
            x -= 51

    def game_loop(self):
        while self.playing:
            self.clock.tick(FPS)

            self.events()
            self.update()
            self.draw()

    def events(self):
        for event in pg.event.get():

            if event.type == pg.QUIT:
                self.playing = False

            if event.type == pg.KEYDOWN:

                if event.key == pg.K_TAB:
                    self.playing = False

                if event.key == pg.K_ESCAPE:
                    self.pause()

        dx = 0

        keys = pg.key.get_pressed()

        if keys[pg.K_LEFT]:
            dx -= 5

        if keys[pg.K_RIGHT]:
            dx += 5

        if keys[pg.K_SPACE]:
            self.player.shoot()

        self.player.move(dx)

    def update(self):

        hits = pg.sprite.spritecollide(
            self.player,
            self.mobs,
            True
        )

        for hit in hits:

            self.player.health -= hit.stealth
            self.player.isDamaged = True

            if hit.name == 'meteor':

                Mob(
                    self.mobs,
                    self.meteorites,
                    self.all_sprites,
                    self.EXPLOSION_MOB
                )

            else:

                Enemy(
                    self.mobs,
                    self.mobs_bullets,
                    self.all_sprites,
                    self.EXPLOSION_MOB
                )

        hits = pg.sprite.groupcollide(
            self.mobs,
            self.bullets,
            False,
            True
        )

        for hit in hits:

            hit.health -= 20
            hit.stealth -= 5

            if hit.health <= 0:

                hit.kill()

                if hit.name == 'meteor':

                    Mob(
                        self.mobs,
                        self.meteorites,
                        self.all_sprites,
                        self.EXPLOSION_MOB
                    )

                    if hit.isBig:
                        self.player.score += 20

                    else:
                        self.player.score += 5

                else:

                    Enemy(
                        self.mobs,
                        self.mobs_bullets,
                        self.all_sprites,
                        self.EXPLOSION_MOB
                    )

                    self.player.score += 10

        hits = pg.sprite.spritecollide(
            self.player,
            self.mobs_bullets,
            True
        )

        for hit in hits:
            self.player.health -= 4
            self.player.isDamaged = True

        hits = pg.sprite.groupcollide(
            self.mobs_bullets,
            self.meteorites,
            True,
            False
        )

        for hit in hits:

            for h in hits[hit]:

                h.health -= 4

                if h.health <= 0:

                    h.kill()

                    Mob(
                        self.mobs,
                        self.meteorites,
                        self.all_sprites,
                        self.EXPLOSION_MOB
                    )

        self.all_sprites.update()

        if self.player.lives < 0:
            self.playing = False

    def draw(self):
        self.screen.blit(self.background, (0, 0))

        self.all_sprites.draw(self.screen)

        self.drawScore(str(abs(self.player.score)))
        self.drawHealth(self.player.health)
        self.drawLife(self.player.lives)

        pg.display.flip()


if __name__ == '__main__':
    Game()
